# TritonAI model hub (LiteLLM OpenAI-compatible proxy). Names only, no values.
TRITONAI_BASE_URL=
TRITONAI_API_KEY=

# Models (must exist in the TritonAI hub).
CHAT_MODEL_PRIMARY=gpt-oss-120b
CHAT_MODEL_FALLBACK=gpt-5.5
EMBED_MODEL=api-tgpt-embeddings

# Model call limits.
MODEL_TIMEOUT_MS=30000
MODEL_MAX_RETRIES=2
MODEL_MAX_TOKENS=900

# Seed-time embedding limits (npm run seed). Embed batches are heavier than chat
# calls, so they have their own, more generous defaults. Tune these if the hub is
# slow during a re-seed: smaller batches and a longer timeout reduce timeouts.
# EMBED_TIMEOUT_MS=60000   # per-batch request timeout (falls back to MODEL_TIMEOUT_MS)
# EMBED_MAX_RETRIES=6      # retries per batch on timeout / 429 / 5xx before giving up
# EMBED_BATCH_SIZE=64      # texts per embeddings request

# Source of the official Division I Manual (LSDBi report). Overridable for pinning.
MANUAL_SOURCE_URL=https://web3.ncaa.org/lsdbi/reports/getReport/90008

# Audit log sink (optional external drain). Defaults to stdout JSON.
# AUDIT_LOG_ENDPOINT=
# AUDIT_LOG_TOKEN=
